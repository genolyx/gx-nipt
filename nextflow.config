/*
 * =========================================================
 *  gx-nipt: Nextflow Configuration
 * =========================================================
 */

// ─────────────────────────────────────────────────────────
// Manifest
// ─────────────────────────────────────────────────────────
manifest {
    name            = 'gx-nipt'
    author          = 'Hyukjung Kwon'
    description     = 'Genolyx NIPT Analysis Pipeline'
    version         = '1.1.0'
    nextflowVersion = '>=23.04.0'
    mainScript      = 'main.nf'
}

// ─────────────────────────────────────────────────────────
// Default parameters
// ─────────────────────────────────────────────────────────
params {
    // ── I/O ──────────────────────────────────────────────
    sample_name   = null
    fastq_r1      = null
    fastq_r2      = null
    labcode       = null
    age           = null
    from_bam      = null
    root_dir      = null
    work_dir      = null
    outdir        = null
    analysisdir   = null

    // ── Execution modes ───────────────────────────────────
    algorithm_only = false
    force          = false

    // ── SSD Scratch Strategy ─────────────────────────────
    // Set scratch_dir to a fast NVMe/SSD mount point (e.g. '/').
    // All BAM files are created there and only the final
    // proper_paired.bam is moved to the analysis directory.
    // Leave as null to use the default Nextflow work directory.
    scratch_dir      = '/tmp/nipt_scratch'  // SSD mount path for BAM scratch
    use_ssd          = false  // set true to activate SSD scratch strategy
    ssd_work_dir     = false  // set true to also place Nextflow workDir on SSD
    ssd_max_usage_gb = 200    // max SSD scratch usage in GB (pipeline aborts if exceeded)

    // ── gx-FF: Improved Fetal Fraction estimation ─────────
    // Set to a .pkl model path to enable gx-FF ensemble.
    // Leave as null to use seqFF-only (legacy behaviour).
    gxff_model     = null   // e.g. /data/nipt/models/gxff_v1.pkl

    // ── gx-cnv: Hybrid dual-track CNV detection ───────────
    // Set to a .npz reference path to enable gx-cnv.
    // Leave as null to skip gx-cnv entirely.
    gxcnv_reference = null   // e.g. /data/nipt/refs/gxcnv_ref.npz
    gxcnv_bin_size  = 100000 // bin size for gxcnv convert (bp)
    gxcnv_thresh_z  = -3.0   // Track A Z-score threshold
    gxcnv_thresh_p  = 0.05   // Track B p-value threshold

    // When true, WisecondorX runs alongside gx-cnv for concordance validation.
    // Set to false once gx-cnv is validated.
    run_wcx = true

    // ── Resource limits ───────────────────────────────────
    max_cpus   = 32
    max_memory = '200.GB'
    max_time   = '24.h'

    // ── Container overrides (allow CLI to swap images) ────
    container_main  = null   // default: gx-nipt:latest
    container_bwa   = null   // default: gx-nipt:latest
    container_gxff  = null   // default: gx-ff:latest
    container_gxcnv = null   // default: gx-cnv:latest

    // ── Reference data root ───────────────────────────────
    // All heavy static reference files (genome + BWA index,
    // HMMcopy wig tracks, per-lab WC/WCX/EZD/PRIZM bundles,
    // seqFF model) live under this directory on the host.
    // The Docker profile below bind-mounts this path into
    // the container at the exact same location, so every
    // module can just open ${params.ref_dir}/... directly.
    //
    // Expected layout:
    //   ${ref_dir}/genomes/hg19/hg19.fa(.fai, .0123, .amb, .ann, .bwt.2bit.64, .pac)
    //   ${ref_dir}/hmmcopy/hg19.{50kb,10mb}.{gc,map}.wig
    //   ${ref_dir}/models/seqff_model.pkl
    //   ${ref_dir}/labs/<labcode>/{WC,WCX,EZD,PRIZM}/<group>/...
    //   ${ref_dir}/labs/<labcode>/bed/...
    ref_dir = '/home/ken/gx-nipt/refs'

    // ── Symlink base for ref_dir ───────────────────────────
    // When ref_dir contains symlinks pointing outside itself (e.g. to
    // ken-nipt/data/refs), that real-path root must also be bind-mounted
    // into every task container so bwa-mem2 / HMMcopy / etc. can resolve
    // them.  Set to "" if ref_dir uses only real (non-symlinked) files.
    ref_symlink_base = '/home/ken/ken-nipt/data'

    // ── Reporting ─────────────────────────────────────────
    // When daemon invokes run_nipt.sh, --tracedir overrides this
    // to a per-sample log/ subdirectory.
    tracedir = "${params.root_dir ?: '.'}/pipeline_info"
}

// ─────────────────────────────────────────────────────────
// Process defaults
// ─────────────────────────────────────────────────────────
process {
    // Default resource allocation
    cpus   = 4
    memory = '8.GB'
    time   = '2.h'

    // Error strategy: retry up to 2 times with increased resources
    errorStrategy = { task.exitStatus in [130, 137, 140, 143] ? 'retry' : 'finish' }
    maxRetries    = 2

    // Resource scaling on retry
    memory = { check_max( 8.GB * task.attempt, 'memory' ) }
    time   = { check_max( 2.h  * task.attempt, 'time'   ) }

    // ── Per-process resource labels ───────────────────────
    withLabel: 'process_low' {
        cpus   = 2
        memory = { check_max( 4.GB  * task.attempt, 'memory' ) }
        time   = { check_max( 1.h   * task.attempt, 'time'   ) }
    }
    withLabel: 'process_medium' {
        cpus   = 8
        memory = { check_max( 16.GB * task.attempt, 'memory' ) }
        time   = { check_max( 4.h   * task.attempt, 'time'   ) }
    }
    withLabel: 'process_high' {
        cpus   = 24
        memory = { check_max( 32.GB * task.attempt, 'memory' ) }
        time   = { check_max( 8.h   * task.attempt, 'time'   ) }
    }
    withLabel: 'process_long' {
        time   = { check_max( 12.h  * task.attempt, 'time'   ) }
    }

    // BWA-MEM2 with 32 threads pre-allocates ~14.6 GB and then reallocates.
    // 32 GB (process_high default) is not enough; set a dedicated higher limit.
    withName: 'BWA_ALIGN' {
        cpus   = 32
        memory = { check_max( 64.GB * task.attempt, 'memory' ) }
        time   = { check_max( 8.h   * task.attempt, 'time'   ) }
    }

    // ── Per-process Docker containers ─────────────────────
    // The user-facing "docker build -t gx-nipt:latest ./docker/" step
    // (see README) produces a local image, so we default to that tag.
    // Override with --container_main / --container_bwa to use a
    // registry-hosted copy (e.g. genolyx/gx-nipt:1.1.0).
    withLabel: 'nipt_docker' {
        container = params.container_main ?: 'gx-nipt:latest'
    }
    withLabel: 'bwa_docker' {
        container = params.container_bwa ?: 'gx-nipt:latest'
    }

    // gx-FF container (LightGBM + DNN inference)
    withName: 'GXFF_PREDICT' {
        container = params.container_gxff ?: 'gx-ff:latest'
        label     = 'process_medium'
    }
    withName: 'GXFF_ENSEMBLE' {
        container = params.container_main ?: 'gx-nipt:latest'
        label     = 'process_low'
    }

    // gx-cnv container
    withName: 'GXCNV_CONVERT' {
        container = params.container_gxcnv ?: 'gx-cnv:latest'
        label     = 'process_medium'
    }
    withName: 'GXCNV_NEWREF' {
        container = params.container_gxcnv ?: 'gx-cnv:latest'
        label     = 'process_high'
    }
    withName: 'GXCNV_PREDICT' {
        container = params.container_gxcnv ?: 'gx-cnv:latest'
        label     = 'process_medium'
    }
    withName: 'GXCNV_COMPARE' {
        container = params.container_main ?: 'gx-nipt:latest'
        label     = 'process_low'
    }
}

// ─────────────────────────────────────────────────────────
// Docker profile (default)
// ─────────────────────────────────────────────────────────
// Launched via `src/run_nipt.sh` which follows the same
// Docker-outside-of-Docker (DooD) pattern as gx-exome:
//
//   host  ──► `docker run gx-nipt:latest nextflow run main.nf ...`
//                 │
//                 │ /var/run/docker.sock is bind-mounted
//                 ▼
//               Nextflow (inside launcher container)
//                 │
//                 ├─► spawns per-task containers on the host daemon
//                 │   using the bind-mounted `docker` CLI.
//                 └─► task containers receive:
//                       * --user ${NXF_DOCKER_TASK_USER}      (uid:gid)
//                       * -v ${NXF_DATA_DIR}:${NXF_DATA_DIR}  (analysis root)
//                       * -v ${params.ref_dir}:${params.ref_dir}:ro
//
// --entrypoint "" is set defensively so Nextflow always runs
// `/bin/bash -c "<process script>"` inside each task container.
docker {
    enabled = true
    temp    = 'auto'

    // Compose runOptions dynamically from launcher-provided env vars
    // so task containers share the same uid:gid as the head JVM and
    // see the same data root path as the host.
    def nxfTaskUser = System.getenv('NXF_DOCKER_TASK_USER')
    def dockerUserOpt = (nxfTaskUser != null && !nxfTaskUser.trim().isEmpty()) \
        ? "--user ${nxfTaskUser}" : ''

    def nxfDataDir = System.getenv('NXF_DATA_DIR')
    def dataDirMount = (nxfDataDir != null && !nxfDataDir.trim().isEmpty()) \
        ? "-v ${nxfDataDir}:${nxfDataDir}" : ''

    // Mount symlink target base (read-only) so task containers can resolve
    // symlinks inside ref_dir that point outside the ref_dir tree.
    def symBase = params.ref_symlink_base?.trim() ?: ''
    def symBaseMount = symBase ? "-v ${symBase}:${symBase}:ro" : ''

    runOptions = "--entrypoint \"\" -e TZ=Asia/Seoul ${dockerUserOpt} ${dataDirMount} -v ${params.ref_dir}:${params.ref_dir}:ro ${symBaseMount}".trim().replaceAll(/ +/, ' ')
}

// ─────────────────────────────────────────────────────────
// Profiles
// ─────────────────────────────────────────────────────────
profiles {
    // Standard Docker execution (default)
    standard {
        docker.enabled = true
        process.executor = 'local'
    }

    // SSD scratch strategy (Strategy B)
    // All BAM I/O goes to the fast NVMe root FS; only
    // proper_paired.bam is archived to the analysis directory.
    // Usage: nextflow run main.nf -profile ssd_scratch ...
    ssd_scratch {
        docker.enabled   = true
        process.executor = 'local'
        params {
            use_ssd          = true
            scratch_dir      = '/tmp/nipt_scratch'  // override with --scratch_dir /your/ssd/path
            ssd_work_dir     = true                 // also place Nextflow workDir on SSD
            ssd_max_usage_gb = 200                  // override with --ssd_max_usage_gb N
        }
        // Redirect Nextflow's own work directory to SSD as well
        workDir = '/tmp/nipt_scratch/nf_work'
        // cleanup=true removes task work dirs after each process completes,
        // preventing SSD garbage accumulation.
        // NOTE: This disables Nextflow's -resume feature.
        cleanup = true
    }

    // Singularity (for HPC environments)
    singularity {
        docker.enabled     = false
        singularity.enabled = true
        singularity.autoMounts = true
        process.executor   = 'local'
    }

    // Slurm HPC cluster
    slurm {
        docker.enabled    = false
        process.executor  = 'slurm'
        process.queue     = 'normal'
        process.clusterOptions = '--account=nipt'
    }

    // Development / test mode (reduced resources)
    test {
        docker.enabled = true
        params {
            max_cpus   = 4
            max_memory = '16.GB'
            max_time   = '2.h'
        }
    }
}

// ─────────────────────────────────────────────────────────
// Reporting & tracing
// ─────────────────────────────────────────────────────────
timeline {
    enabled = true
    file    = "${params.tracedir}/timeline.html"
    overwrite = true
}

report {
    enabled = true
    file    = "${params.tracedir}/report.html"
    overwrite = true
}

trace {
    enabled   = true
    file      = "${params.tracedir}/trace.txt"
    overwrite = true
    fields    = 'task_id,name,status,exit,realtime,%cpu,peak_rss,peak_vmem,rchar,wchar'
}

dag {
    enabled = true
    file    = "${params.tracedir}/pipeline_dag.html"
    overwrite = true
}

// ─────────────────────────────────────────────────────────
// Helper functions
// ─────────────────────────────────────────────────────────
def check_max(obj, type) {
    if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else
                return obj
        } catch (all) {
            println "WARNING: Max memory '${params.max_memory}' is not valid. Using default value: $obj"
            return obj
        }
    } else if (type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                return params.max_time as nextflow.util.Duration
            else
                return obj
        } catch (all) {
            println "WARNING: Max time '${params.max_time}' is not valid. Using default value: $obj"
            return obj
        }
    } else if (type == 'cpus') {
        try {
            return Math.min( obj, params.max_cpus as int )
        } catch (all) {
            println "WARNING: Max cpus '${params.max_cpus}' is not valid. Using default value: $obj"
            return obj
        }
    }
}
